# Calendly (optionnel — la valeur par défaut est dans src/lib/site.ts)
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/felixmachenaud2/30min

# Formulaire contact — Resend (https://resend.com)
# Créez une clé API, puis sur Vercel / votre hébergeur : Variables d’environnement.
RESEND_API_KEY=re_xxxxxxxx

# Expéditeur : avec le domaine de test Resend, utilisez par ex.
# WebSite Studio <onboarding@resend.dev>
# (les emails de test ne peuvent aller qu’à l’adresse de votre compte Resend.)
# Avec un domaine vérifié sur Resend :
# WebSite Studio <contact@votredomaine.com>
RESEND_FROM_EMAIL=WebSite Studio <onboarding@resend.dev>

# Optionnel : destinataire (par défaut : CONTACT_EMAIL dans src/lib/site.ts)
# CONTACT_TO_EMAIL=felixmachenaud2@gmail.com

# Vidéo « Hautefeuille » si le fichier MP4 n’est pas dans le repo (fichier > 100 Mo GitHub)
# Mettez l’URL complète hébergée ailleurs (CDN, S3, etc.)
# NEXT_PUBLIC_VIDEO_HAUTEFEUILLE_URL=https://exemple.com/chemin/vers/hautefeuille.mp4
